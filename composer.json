{
    "name": "maispace/mai-base",
    "description": "Base foundation extension for Maispace TYPO3 projects. Provides shared TypoScript configuration, page layout definitions, and pulls in all TYPO3 backend/infrastructure extensions that the project requires. Mail dispatch is handled by `mai_mail` \u2014 no external mail queue package is declared here.",
    "type": "typo3-cms-extension",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Maispace",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.4 || ^14.0",
        "typo3/cms-adminpanel": "^13.4 || ^14.0",
        "typo3/cms-backend": "^13.4 || ^14.0",
        "typo3/cms-belog": "^13.4 || ^14.0",
        "typo3/cms-beuser": "^13.4 || ^14.0",
        "typo3/cms-dashboard": "^13.4 || ^14.0",
        "typo3/cms-extensionmanager": "^13.4 || ^14.0",
        "typo3/cms-impexp": "^13.4 || ^14.0",
        "typo3/cms-indexed-search": "^13.4 || ^14.0",
        "typo3/cms-info": "^13.4 || ^14.0",
        "typo3/cms-lowlevel": "^13.4 || ^14.0",
        "typo3/cms-opendocs": "^13.4 || ^14.0",
        "typo3/cms-reactions": "^13.4 || ^14.0",
        "typo3/cms-recycler": "^13.4 || ^14.0",
        "typo3/cms-reports": "^13.4 || ^14.0",
        "typo3/cms-setup": "^13.4 || ^14.0",
        "typo3/cms-sys-note": "^13.4 || ^14.0",
        "typo3/cms-tstemplate": "^13.4 || ^14.0",
        "typo3/cms-viewpage": "^13.4 || ^14.0",
        "typo3/cms-webhooks": "^13.4 || ^14.0",
        "typo3/cms-workspaces": "^13.4 || ^14.0",
        "evoweb/extender": "^11.0"
    },
    "require-dev": {
        "armin/editorconfig-cli": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.0",
        "helmich/typo3-typoscript-lint": "^3.1",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "saschaegerer/phpstan-typo3": "^2.0",
        "typo3/testing-framework": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Maispace\\MaiBase\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maispace\\MaiBase\\Tests\\": "Tests"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "mai_base"
        },
        "branch-alias": {
            "dev-main": "13.0.x-dev"
        }
    },
    "scripts": {
        "lint:check": [
            "@check:editorconfig",
            "@check:phpcs",
            "@check:phpstan",
            "@check:typoscript",
            "@composer validate --strict --no-check-version --no-check-all --no-check-publish"
        ],
        "lint:fix": [
            "@fix:editorconfig",
            "@fix:phpcs",
            "@check:phpstan",
            "@check:typoscript"
        ],
        "check:editorconfig": "ec -unv -e vendor/ -e public/",
        "fix:editorconfig": "ec -unvf -e vendor/ -e public/",
        "check:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer check --config .php-cs-fixer.php --ansi --verbose --diff",
        "fix:phpcs": "PHP_CS_FIXER_IGNORE_ENV=1 php-cs-fixer fix --config .php-cs-fixer.php --ansi",
        "check:phpstan": "phpstan analyse --no-progress",
        "check:phpstan:baseline": "phpstan analyse --no-progress --generate-baseline=phpstan-baseline.neon",
        "check:typoscript": "typoscript-lint --fail-on-warnings -c typoscript-lint.yml Configuration/",
        "test": "phpunit --configuration phpunit.xml.dist",
        "test:unit": "phpunit --configuration phpunit.xml.dist --testsuite Unit"
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        },
        "sort-packages": true
    }
}
