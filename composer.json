  "description": "Base Extension for Maispace Projects",
  "homepage": "https://www.maispace.de",
  "authors": [
    {
      "name": "Joel Maximilian Mai",
      "email": "joel@maispace.de",
      "role": "Lead Developer"
    }
  ],
  "require": {
